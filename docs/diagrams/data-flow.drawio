<mxfile host="Electron" version="29.5.2">
  <diagram id="dataflow" name="Page-1">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Left column: execution pipeline -->
        <mxCell id="yaml" value="workflow.yaml" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="30" width="180" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="parse" value="spec.Parse()&#xa;Go CLI: validate YAML, check DAG" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="220" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="compile" value="compile(spec)&#xa;Deno: Kahn's algorithm, topological sort, stages" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="195" width="220" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="postrun" value="POST /run" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="140" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="resolve" value="resolveInput()" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="runner" value="runner.run(nodeId, ctx, input)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="55" y="435" width="190" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="result" value="ExecutionResult" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="response" value="JSON Response" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontFamily=Helvetica;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="585" width="180" height="40" as="geometry"/>
        </mxCell>

        <!-- Left column arrows -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" parent="1" source="yaml" target="parse">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" parent="1" source="parse" target="compile">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" parent="1" source="compile" target="postrun">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" parent="1" source="postrun" target="resolve">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" parent="1" source="resolve" target="runner">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" parent="1" source="runner" target="result">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#666666;" edge="1" parent="1" source="result" target="response">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Right column: executor stages -->
        <mxCell id="executor" value="SimpleExecutor.execute()" style="swimlane;startSize=28;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;fontStyle=1;fontSize=11;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="270" width="420" height="340" as="geometry"/>
        </mxCell>

        <mxCell id="stage1" value="Stage 1: [fetch-repos]" style="swimlane;startSize=22;fillColor=#e6ffe6;strokeColor=#82b366;fontFamily=Helvetica;fontStyle=1;fontSize=10;rounded=1;" vertex="1" parent="executor">
          <mxGeometry x="20" y="40" width="380" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s1_call" value="ctx.fetch(&quot;github&quot;, &quot;/user/repos&quot;)" style="text;fontFamily=Helvetica;fontSize=9;fontColor=#666666;" vertex="1" parent="stage1">
          <mxGeometry x="10" y="28" width="200" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="s1_out" value="output: { repos: [...] }" style="text;fontFamily=Helvetica;fontSize=9;fontColor=#333333;fontStyle=1;" vertex="1" parent="stage1">
          <mxGeometry x="10" y="48" width="200" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="stage2" value="Stage 2: [summarize]" style="swimlane;startSize=22;fillColor=#e6ffe6;strokeColor=#82b366;fontFamily=Helvetica;fontStyle=1;fontSize=10;rounded=1;" vertex="1" parent="executor">
          <mxGeometry x="20" y="130" width="380" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s2_in" value="input: { repos: [...] }" style="text;fontFamily=Helvetica;fontSize=9;fontColor=#666666;" vertex="1" parent="stage2">
          <mxGeometry x="10" y="28" width="200" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="s2_out" value="output: { summary: &quot;...&quot; }" style="text;fontFamily=Helvetica;fontSize=9;fontColor=#333333;fontStyle=1;" vertex="1" parent="stage2">
          <mxGeometry x="10" y="48" width="200" height="18" as="geometry"/>
        </mxCell>

        <mxCell id="stage3" value="Stage 3: [notify]" style="swimlane;startSize=22;fillColor=#e6ffe6;strokeColor=#82b366;fontFamily=Helvetica;fontStyle=1;fontSize=10;rounded=1;" vertex="1" parent="executor">
          <mxGeometry x="20" y="220" width="380" height="75" as="geometry"/>
        </mxCell>
        <mxCell id="s3_in" value="input: { summary: &quot;...&quot; }" style="text;fontFamily=Helvetica;fontSize=9;fontColor=#666666;" vertex="1" parent="stage3">
          <mxGeometry x="10" y="28" width="200" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="s3_out" value="output: { sent: true }" style="text;fontFamily=Helvetica;fontSize=9;fontColor=#333333;fontStyle=1;" vertex="1" parent="stage3">
          <mxGeometry x="10" y="48" width="200" height="18" as="geometry"/>
        </mxCell>

        <!-- Arrows between stages -->
        <mxCell id="sa1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" parent="executor" source="stage1" target="stage2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="sa2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;" edge="1" parent="executor" source="stage2" target="stage3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Connector: POST /run to executor -->
        <mxCell id="conn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#82b366;strokeWidth=2;dashed=1;" edge="1" parent="1" source="postrun" target="executor">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
